<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-900 text-white p-10">
  <div>
    <a href="/" class="text-blue-500 hover:text-blue-400">Create User</a>
  </div>

  <h1 class="text-3xl font-bold text-center mb-10">All Users</h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

    <% users.forEach(user => { %>
      <div class="bg-zinc-800 rounded-2xl overflow-hidden shadow-lg border border-zinc-700">

        <!-- Image -->
        <img src="<%= user.image || 'https://via.placeholder.com/300' %>" 
             class="w-full h-48 object-cover" 
             alt="user image">

        <!-- Content -->
        <div class="p-5">
          <h2 class="text-xl font-semibold"><%= user.name %></h2>
          <p class="text-zinc-400 text-sm"><%= user.email %></p>

          <!-- Edit & Delete -->
          <div class="flex gap-4 mt-4 text-sm">

            <a href="/edit/<%= user._id %>" class="text-zinc-500 hover:text-blue-400 transition">
              Edit User
            </a>

            <form action="/delete/<%= user._id %>" method="POST">
              <button class="text-red-500 hover:text-red-400 transition" type="submit">
                Delete
              </button>
            </form>

          </div>
        </div>

      </div>
    <% }) %>

  </div>

</body>

</html>